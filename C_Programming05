#include <stdio.h>
void count_total_digits()
{
    int num, count = 0;
    printf("Enter a number: ");
    scanf("%d", &num);
    if(num == 0)
    {
        count = 1;
    }
    else
    {
        while(num != 0)
        {
            count++;
            num /= 10;
        }
    }
    printf("Total digits = %d\n", count);
}
int main()
{
    count_total_digits();
    return 0;
}
