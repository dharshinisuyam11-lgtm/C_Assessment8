#include <stdio.h>
void disp_sum_all_digits()
{
    int num, digit, sum = 0;
    printf("Enter a number: ");
    scanf("%d", &num);
    while(num != 0)
    {
        digit = num % 10;
        sum += digit;
        num /= 10;
    }
    printf("Sum of digits = %d\n", sum);
}
int main()
{
    disp_sum_all_digits();
    return 0;
}
