#include <stdio.h>
void disp_reverse_number()
{
    int num, rev = 0, digit;
    printf("Enter a number: ");
    scanf("%d", &num);
    while(num != 0)
    {
        digit = num % 10;
        rev = rev * 10 + digit;
        num /= 10;
    }
    printf("Reverse number = %d\n", rev);
}
int main()
{
    disp_reverse_number();
    return 0;
}
