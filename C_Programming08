#include <stdio.h>
void disp_interchange_first_last_digit()
{
    int num, first, last, middle, temp, digits = 0, power = 1;
    printf("Enter a number: ");
    scanf("%d", &num);
    temp = num;
    last = num % 10;
    while(temp >= 10)
    {
        temp /= 10;
        digits++;
        power *= 10;
    }
    first = temp;
    middle = (num % power) / 10;
    num = last * power + middle * 10 + first;
    printf("Number after interchange = %d\n", num);
}
int main()
{
    disp_interchange_first_last_digit();
    return 0;
}
