#include <stdio.h>
void disp_2digit_even_sum6()
{
    int count = 0, i, j, prime;
    for(i = 1; i <= 9; i++)
    {
        prime = 1;
        if(i < 2)
            prime = 0;
        else
        {
            for(j = 2; j < i; j++)
            {
                if(i % j == 0)
                {
                    prime = 0;
                    break;
                }
            }
        }
        if(prime)
            count++;
    }
    printf("Total single digit prime numbers = %d\n", count);
}
int main()
{
    disp_2digit_even_sum6();
    return 0;
}
