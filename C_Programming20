#include <stdio.h>
void disp_hcf(int a, int b)
{
    int i, hcf = 1;
    for(i = 1; i <= a && i <= b; i++)
    {
        if(a % i == 0 && b % i == 0)
            hcf = i;
    }
    printf("HCF = %d", hcf);
}
int main()
{
    int a, b;
    printf("Enter two numbers: ");
    scanf("%d%d", &a, &b);
    disp_hcf(a, b);
    return 0;
}
